{
  "id": "10-by-cpv-sector-reconcile",
  "prompt": "Разход по сектор 45 (строителство)",
  "steps": [
    {
      "tool": "run_sql",
      "sql": "SELECT substr(t.cpv_code, 1, 2) AS division, COUNT(*) AS contracts, SUM(c.amount_eur) AS value_eur FROM contracts c JOIN tenders t ON t.id = c.tender_id WHERE c.amount_eur IS NOT NULL AND t.procedure_type != 'неизвестна' AND substr(t.cpv_code, 1, 2) = '45' GROUP BY division",
