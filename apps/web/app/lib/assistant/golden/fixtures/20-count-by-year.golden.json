{
  "id": "20-count-by-year",
  "prompt": "Брой договори по година",
  "steps": [
    {
      "tool": "run_sql",
      "sql": "SELECT substr(c.signed_at, 1, 4) AS year, COUNT(*) AS contracts FROM contracts c JOIN tenders t ON t.id = c.tender_id WHERE c.amount_eur IS NOT NULL AND t.procedure_type != 'неизвестна' AND c.signed_at IS NOT NULL GROUP BY year ORDER BY year LIMIT 5",
