    "sources": [
      {
        "handle": "R1",
        "tool": "run_sql",
        "sql": "WITH c AS (SELECT b.name AS company, b.eik AS eik, SUM(ct.amount_eur) AS total_eur, COUNT(*) AS contracts FROM contracts ct JOIN bidders b ON b.id = ct.bidder_id JOIN tenders t ON t.id = ct.tender_id WHERE ct.amount_eur IS NOT NULL AND substr(t.cpv_code,1,2) = '45' AND strftime('%Y', ct.signed_at) = '2023' GROUP BY b.eik ORDER BY total_eur DESC LIMIT 5) SELECT company, eik, total_eur, contracts FROM c"
      }
