# Copied to .dev.vars by .devcontainer/post-create.sh - fill in before `pnpm dev`.
# .dev.vars is gitignored. Never commit real secrets (see AGENTS.md).

# Public EOP open-data MinIO feed.
# Code defaults to https://storage.eop.bg (apps/etl, scripts/load-eop.mjs) - set only to override.
# EOP_OPEN_DATA_BASE_URL=https://storage.eop.bg

# Web worker privacy-preserving request log IP HMAC key.
LOG_IP_KEY=dev-only-log-ip-key-change-me

# AI assistant transcript signing key (HMAC-SHA-256 over server-emitted messages).
# Prod: `wrangler secret put ASSISTANT_HMAC_KEY`. Never commit the real value.
ASSISTANT_HMAC_KEY=dev-only-assistant-hmac-key-change-me
