{
  "name": "sigma",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // Relax the default Docker seccomp/apparmor profiles so Codex's bundled
  // bubblewrap (bwrap) can create the user namespace its sandbox needs.
  // Without this, `unshare(CLONE_NEWUSER)` is blocked and codex-workers fail
  // with "bwrap: No permissions to create a new namespace".
  "runArgs": ["--security-opt", "seccomp=unconfined", "--security-opt", "apparmor=unconfined"],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteUser": "node",
  // Pin the source mount to /workspaces/sigma regardless of the host folder name.
  // Without this, Dev Containers mounts the repo at /workspaces/<host-basename>
  // (e.g. /workspaces/sigma-prototype), while workspaceFolder + the node_modules
  // volume target /workspaces/sigma — leaving that dir with only node_modules in it
  // and breaking post-create's pnpm install (no package.json at cwd).
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/sigma,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/sigma",
  "forwardPorts": [5173, 8789],
  "portsAttributes": {
    "5173": { "label": "web (React Router dev)" },
    "8789": { "label": "etl (wrangler dev)" }
  },
  "otherPortsAttributes": { "onAutoForward": "notify" },
  "mounts": [
    "source=sigma-node-modules,target=/workspaces/sigma/node_modules,type=volume",
    "source=sigma-pnpm-store,target=/home/node/.pnpm-store,type=volume",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind"
  ],
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml",
        "qwtel.sqlite-viewer",
        "cloudflare.vscode-cloudflare-workers",
        "anthropic.claude-code",
        "github.vscode-github-actions",
        "sanjulaganepola.github-local-actions",
        "bierner.markdown-mermaid",
        "mechatroner.rainbow-csv"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
